# Contabo production — copy values into /var/www/nassani-admin/server/.env
# PostgreSQL runs ON this Contabo VPS (independent from Osmani / Vultr).

NODE_ENV=production
PORT=10001

# --- PostgreSQL (local Contabo) ---
DATABASE_URL=postgresql://nassani:CHANGE_ME@127.0.0.1:5432/nassani_db

# --- PostgreSQL pool ---
NASSANI_VPS=1
PG_POOL_MAX=30
PG_POOL_CONNECT_TIMEOUT_MS=5000
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_QUERY_TIMEOUT_MS=8000
VERIFY_DB_MAX_CONCURRENT=25
VERIFY_DB_SLOT_WAIT_MS=30000
APP_SETTINGS_CACHE_MS=30000
GLOBAL_MODES_CACHE_MS=15000
SUBSCRIPTION_ACCESS_CACHE_MS=5000
PG_POOL_STATS=1

# --- Public URLs ---
# Until DNS/TLS: http://VPS_IP
# BASE_URL=http://169.58.18.86
# STREAM_API_BASE_URL=http://169.58.18.86
# ADMIN_PUBLIC_URL=http://169.58.18.86
BASE_URL=https://api.nassanitv.com
STREAM_API_BASE_URL=https://api.nassanitv.com
ADMIN_PUBLIC_URL=https://admin.nassanitv.com

# Optional Bunny pull CDN for thumbnails/static only (NOT for HLS video origin).
BUNNY_CDN_BASE_URL=
ASSET_LEGACY_ORIGIN_HOSTS=169.58.18.86,api.nassanitv.com,admin.nassanitv.com

UPLOAD_DIR=/var/www/nassani-admin/server/uploads

ADMIN_API_TOKEN=CHANGE_ME
ADMIN_JWT_SECRET=CHANGE_ME

# Channel stream_url / playback should be CDN HLS (.m3u8) — VPS stores metadata only.
STREAM_DELIVERY_MODE=direct
DIRECT_STREAM_SIGNING_ENABLED=0
STREAM_PLAYBACK_FORCE_PROXY=0
DIRECT_STREAM_CUTOVER_ENABLED=1
DIRECT_STREAM_ROLLOUT_PERCENT=100
