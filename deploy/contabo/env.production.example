# Contabo production — copy to /var/www/osmani-admin/server/.env
# MUST use the same Vultr PostgreSQL DATABASE_URL as Render production.

NODE_ENV=production
PORT=10001

# --- PostgreSQL (Vultr production — same as Render) ---
DATABASE_URL=postgresql://USER:PASSWORD@VULTR_HOST:5432/DBNAME

# --- PostgreSQL pool (VPS — tune for Vultr capacity) ---
OSMANI_VPS=1
PG_POOL_MAX=18
PG_POOL_CONNECT_TIMEOUT_MS=5000
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_QUERY_TIMEOUT_MS=8000
VERIFY_DB_MAX_CONCURRENT=12
VERIFY_DB_SLOT_WAIT_MS=1200
PG_QUERY_TIMEOUT_MS=8000
APP_SETTINGS_CACHE_MS=30000
GLOBAL_MODES_CACHE_MS=15000
SUBSCRIPTION_ACCESS_CACHE_MS=5000
PG_POOL_STATS=1

# --- Public URLs (Contabo cutover) ---
# Legacy IP (HTTP testing only — redirects to HTTPS when branded nginx is active):
# BASE_URL=http://144.91.117.90
# STREAM_API_BASE_URL=http://144.91.117.90
# Branded HTTPS (VPS production / Google Play):
BASE_URL=https://api.osmanitv.com
STREAM_API_BASE_URL=https://api.osmanitv.com
ADMIN_PUBLIC_URL=https://admin.osmanitv.com

# Bunny CDN — REQUIRED for channel/banner thumbnails (files live on Render disk; CDN still serves them).
BUNNY_CDN_BASE_URL=https://osmanitv.b-cdn.net

# Legacy absolute URLs in DB (Render IP, Contabo IP, localhost) → Bunny on API read.
ASSET_LEGACY_ORIGIN_HOSTS=144.91.117.90,osmani-admin-api.onrender.com,api.osmanitv.com,admin.osmanitv.com

# --- Media uploads (sync from Render disk or Bunny-only reads) ---
UPLOAD_DIR=/var/www/osmani-admin/media

# --- Admin panel legacy token (required for admin routes when ADMIN_PANEL_AUTH_REQUIRED is false) ---
ADMIN_API_TOKEN=CHANGE_ME

# --- Stream delivery (match Render production) ---
STREAM_DELIVERY_MODE=hybrid
DIRECT_STREAM_SIGNING_ENABLED=1
STREAM_PLAYBACK_FORCE_PROXY=1
DIRECT_STREAM_CUTOVER_ENABLED=0
DIRECT_STREAM_ROLLOUT_PERCENT=0

# Payment webhooks must point at Contabo after cutover:
# ZENO_WEBHOOK_URL=http://144.91.117.90/api/zeno-webhook
