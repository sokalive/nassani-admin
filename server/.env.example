# Optional — default is 4000
PORT=4000

# SSE subscription-stream poll fallback interval (ms) (default 2500)
# MODE_SSE_POLL_MS=2500

# PostgreSQL (required for channels storage)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Channels: log display_section parse + persist (incoming value, stored slug, final); off by default
# DISPLAY_SECTION_STRICT_DEBUG=1

# Billing: log subscription stacking (previous expiry, anchor, duration, final expires_at); off by default
# SUBSCRIPTION_STACK_DEBUG=1

# Subscription verify (GET /subscription-status, POST /subscription/verify): txn summary + normalized amount/duration
# SUBSCRIPTION_VERIFY_DEBUG=1

# --- Manual subscription grant (admin POST /admin/manual-subscription/grant) ---
# Required secret PIN (server validates with timing-safe hash compare); min length 4
# MANUAL_SUBSCRIPTION_ADMIN_PIN=
# ADMIN_SENSITIVE_ACTION_PASSWORD=3030   # Security Center, Admin Security, Toa Kifurushi grant (default 3030)
# Logs grant payload + gift ack (optional)
# MANUAL_SUBSCRIPTION_DEBUG=1
# Max grants per client IP per hour (default 30)
# MANUAL_GRANT_RATE_LIMIT_PER_HOUR=30

# First-time PIN setup endpoint rate limit (default 20 / IP / hour)
# MANUAL_PIN_SETUP_RATE_LIMIT_PER_HOUR=20
# Optional: set to disable SSL for local Postgres
# PGSSLMODE=disable

# --- Analytics live presence ---
# Dashboard "live" window: rows count if updated within N seconds (default 45, clamp 10–120).
# Mobile heartbeats are often 30–60s apart — too tight a window under-counts live viewers.
# ANALYTICS_LIVE_PRESENCE_WINDOW_SECONDS=60   # default 60 (legacy APK heartbeats up to ~60s apart)
# APP_UPDATE_NEVER_MIN=24   # v24+ never see update popup
# SUBSCRIPTION_ACCESS_CACHE_MS=3000
# SUBSCRIPTION_RECONCILE_MIN_INTERVAL_MS=30000
# SUBSCRIPTION_VERIFY_MAX_MS=2500
# DELETE idle live_sessions rows after N seconds (default max(window+30, 90)).
# ANALYTICS_SESSION_PRUNE_SECONDS=90
# Background stale-session cleanup interval ms (default 10000).
# ANALYTICS_PRESENCE_JANITOR_MS=10000
# Legacy alias for live window only (clamped 10–45); prefer ANALYTICS_LIVE_PRESENCE_WINDOW_SECONDS.
# ANALYTICS_SESSION_TTL_SECONDS=18

# Public base URL for absolute thumbnail URLs in /api/channels (optional)
# BASE_URL=https://api.nassanitv.online

# --- PostgreSQL pool (single Render Starter instance) ---
# PG_POOL_MAX=8
# PG_POOL_IDLE_TIMEOUT_MS=30000
# PG_POOL_LOG=1

# --- Server Health admin probes ---
# Probes every channel stream URL; expensive. Off by default (GET /api/server-health still works).
# SERVER_HEALTH_BACKGROUND_ENABLED=0
# SERVER_HEALTH_BROADCAST_INTERVAL_MS=60000
# SERVER_HEALTH_CACHE_MS=20000

# --- In-memory API response cache (public catalog GET only) ---
# API_CACHE_ENABLED=1
# API_CACHE_MAX_ENTRIES=48
# API_CACHE_CHANNELS_TTL_MS=20000
# API_CACHE_BANNERS_TTL_MS=20000
# API_CACHE_PLANS_TTL_MS=60000
# API_CACHE_DEBUG=1

# --- Stream delivery (Nassani HMAC + optional Bunny segment offload) ---
# STREAM_DELIVERY_MODE=direct
# DIRECT_STREAM_SIGNING_ENABLED=1
# DIRECT_STREAM_SIGNING_SECRET=   # min 16 chars; Nassani-only secret (never reuse Osmani)
# STREAM_PLAYBACK_FORCE_PROXY=0
# DIRECT_STREAM_CUTOVER_ENABLED=1
# DIRECT_STREAM_ROLLOUT_PERCENT=0       # 0 when using allowlist canaries
# DIRECT_STREAM_ROLLOUT_CHANNEL_IDS=3,4,5   # HLS canaries; HTML players stay upstream
# DIRECT_STREAM_ROLLOUT_SALT=nassani-stream-rollout-v1
# DIRECT_STREAM_TOKEN_TTL_SEC=120
# STREAM_SEGMENT_TOKEN_TTL_SEC=600
# STREAM_SEGMENT_DELIVERY=bunny        # proxy | bunny | hybrid
# STREAM_SEGMENT_FORCE_PROXY=0
# STREAM_SEGMENT_SELECTIVE_ROUTING=1
# STREAM_SEGMENT_ROLLOUT_PERCENT=100
# STREAM_SEGMENT_ROLLOUT_SALT=nassani-seg-v1
# STREAM_API_BASE_URL=https://api.nassanitv.online  # stream-direct/proxy only (never Bunny CDN)
# DIRECT_STREAM_BASE_URL=              # optional; defaults to STREAM_API_BASE_URL / BASE_URL (Bunny hosts rejected)

# --- Bunny CDN ---
# Static /uploads/*: leave BUNNY_CDN_BASE_URL empty so images/APKs stay on
# https://api.nassanitv.online/uploads/... (VPS disk). Do not rewrite to Bunny.
# BUNNY_CDN_BASE_URL=
# UPLOADS_SERVE_FROM_ORIGIN=1
#
# HLS streaming only (signed /hls/seg via Nassani pull zone):
# BUNNY_STREAM_CDN_BASE_URL=https://nassanitv.b-cdn.net
# BUNNY_STREAM_SEGMENT_PATH=hls/seg
# BUNNY_SEGMENT_CACHE_MAX_AGE_SEC=86400
# STREAM_SEGMENT_DELIVERY=bunny
# STREAM_SEGMENT_FORCE_PROXY=0
# STREAM_SEGMENT_SELECTIVE_ROUTING=1
# STREAM_SEGMENT_ROLLOUT_PERCENT=100
# STREAM_SEGMENT_ROLLOUT_SALT=nassani-seg-v1
# BUNNY_PULL_ZONE_ID=
# BUNNY_API_KEY=
# BUNNY_PULL_ORIGIN_SECRET=            # optional; only after edge rule sends X-Bunny-Origin-Auth
# ASSET_LEGACY_ORIGIN_HOSTS=

# IPTV stream delivery diagnostics (logs structured JSON per matching channel; off by default)
# CHANNEL_STREAM_DIAG=1
# Optional: substring to match channel url (default ycn-redirect). Use empty string to include all channels.
# CHANNEL_STREAM_DIAG_MATCH=ycn-redirect
# CHANNEL_STREAM_DIAG_FULL_URLS=1

# Stream proxy diagnostics / defaults
# STREAM_PROXY_USER_AGENT=Mozilla/5.0 ...

# --- Media uploads (banners, channels, payment logos) ---
# Production (Render): set to your persistent disk mount path — NEVER rely on the repo's server/uploads for prod.
# UPLOAD_DIR=/var/render/media
# Optional: fail deploy if disk missing (stricter ops)
# REQUIRE_UPLOAD_DIR=1
#
# Public URLs stay /uploads/<filename>; DB stores /uploads/... paths. Only the filesystem root moves.

# --- Notification images (always on VPS disk — never Render local storage) ---
# Render: NOTIFICATION_IMAGE_STORAGE=remote + ingest URL pointing at VPS.
# NOTIFICATION_IMAGE_VPS_INGEST_URL=https://api.nassanitv.online/api/internal/notification-images
# NOTIFICATION_IMAGE_PUBLIC_ORIGIN=https://api.nassanitv.online
# NOTIFICATION_IMAGE_INGEST_TOKEN=   # shared secret Render→VPS (defaults to ADMIN_API_TOKEN)
# NOTIFICATION_IMAGE_RETENTION_DAYS=90
# NOTIFICATION_IMAGE_CLEANUP_INTERVAL_MS=86400000

# ZenoPay (optional overrides — admin UI can persist same keys in PostgreSQL)
# ZENO_API_KEY=
# ZENO_ACCOUNT_ID=
# ZENO_WEBHOOK_URL=https://api.nassanitv.online/api/zeno-webhook
# ZENO_ENDPOINT=https://zenoapi.com
# ZENO_PAYMENT_URL=   # optional: full POST URL for create-payment (default: ZENO_ENDPOINT + /api/payments/mobile_money_tanzania)
# ZENO_CONNECTIVITY_PROBE_URL=   # optional: URL for "Test connection" HEAD/GET (default: host from ZENO_ENDPOINT only — avoids GET on POST-only paths)
# ZENO_COLLECT_PATH=/api/payments/mobile_money_tanzania   # optional: path appended to ZENO_ENDPOINT, or full https URL

# SonicPesa (optional overrides — admin UI persists in sonicpesa_settings; checkout provider in checkout_payment_settings)
# SONICPESA_API_KEY=
# SONICPESA_ACCOUNT_ID=
# SONICPESA_ENDPOINT=https://api.sonicpesa.com/api/v1
# SONICPESA_WEBHOOK_SECRET=   # optional: HMAC verify on POST /api/payments/sonicpesa/webhook (header x-sonicpesa-signature)
# SONICPESA_CREATE_ORDER_PATH=/payment/create_order   # optional path under SONICPESA_ENDPOINT
# SONICPESA_ORDER_STATUS_PATH=/payment/order_status   # POST body { order_id } — provider order id (sp_…)
# SONICPESA_ORDER_STATUS_URL=   # optional full URL override for status poll
# SONICPESA_SECRET_KEY=   # optional; some SDKs send X-SECRET-KEY with the API key
# SONICPESA_BUYER_EMAIL=customer@nassanitv.online
# SONICPESA_BUYER_NAME=Nassani Customer
# SONICPESA_INCLUDE_MERCHANT_REF=1   # off by default — API expects buyer_* + amount only
# SONICPESA_VERIFY_PATH=   # optional verify/status path override

# Aurax Pay (optional overrides — admin UI persists in auraxpay_settings; checkout provider in checkout_payment_settings)
# AURAXPAY_API_KEY=
# AURAXPAY_SIGNING_SECRET=   # outbound API + webhook HMAC (alias: AURAXPAY_SECRET_KEY, AURAXPAY_WEBHOOK_SECRET)
# AURAXPAY_ACCOUNT_ID=   # merchant phone (255XXXXXXXXX) — AuraxPay account id
# AURAXPAY_ENDPOINT=https://api.auraxpay.net/v1   # alias: AURAXPAY_BASE_URL
# AURAXPAY_BASE_URL=https://api.auraxpay.net/v1   # native Aurax → POST …/v1/payments/collect
# AURAXPAY_API_STYLE=aurax   # aurax (default) | trawx | zenopay | sonicpesa
# AURAXPAY_WEBHOOK_URL=   # optional; default {BASE_URL}/api/payments/auraxpay/webhook (alias: POST /api/webhooks/aurax)
# AURAXPAY_WEBHOOK_SECRET=   # optional: HMAC verify on POST /api/payments/auraxpay/webhook (header x-auraxpay-signature)
# AURAXPAY_COLLECT_PATH=/payments/collect   # native default; trawx uses /api/create-order; or full URL via AURAXPAY_COLLECT_URL
# AURAXPAY_ORDER_STATUS_PATH=/api/get_status   # Trawx GET /api/get_status/{ref}; override with AURAXPAY_ORDER_STATUS_URL
# AURAXPAY_ORDER_STATUS_URL=   # optional full URL override for status poll

# Beem SMS (optional overrides — admin UI persists in beem_settings)
# BEEM_API_KEY=
# BEEM_SECRET_KEY=
# BEEM_SENDER_NAME=NASSANITVMAX
# BEEM_SMS_ENDPOINT=https://apisms.beem.africa/v1/send
# BEEM_SMS_ENABLED=1   # optional force-enable when DB row is disabled
# SMS_EXPIRY_REMINDER_MS=3600000   # expiry reminder scheduler interval (default 1 hour)

# --- OneSignal push (Nassani app — set on VPS only, never commit secrets) ---
# ONESIGNAL_APP_ID=
# ONESIGNAL_REST_API_KEY=
# ONESIGNAL_AUTH_SCHEME=auto   # auto | key | basic (legacy REST API key)
# ONESIGNAL_STATS_REFRESH_MS=30000
# ONESIGNAL_STATS_STALE_MS=45000
# NOTIFICATIONS_SCHEDULER_MS=30000
# NOTIFICATION_IMAGE_PUBLIC_ORIGIN=https://api.nassanitv.online
# NOTIFICATION_IMAGE_STORAGE=local

# --- Nassani admin panel login (JWT + trusted device + Resend OTP) ---
# NOTE: Tables are admin_panel_users / admin_panel_trusted_devices / admin_panel_login_otps
#       (separate from subscriber admin_devices + transfer admin_otp_codes).
#
# Enable email/password + OTP gate for /api/admin/manual-subscription and /api/admin/offer-codes.
# ADMIN_PANEL_AUTH_REQUIRED=false
#
# Strong secret for signing panel JWTs (required when ADMIN_PANEL_AUTH_REQUIRED=true).
# ADMIN_JWT_SECRET=
#
# First admin user when admin_panel_users is empty (password min 8 chars). Remove after creating users if desired.
# ADMIN_PANEL_BOOTSTRAP_EMAIL=admin@example.com
# ADMIN_PANEL_BOOTSTRAP_PASSWORD=
#
# Optional: allow X-Admin-Token alone while migrating (not recommended long-term).
# ADMIN_PANEL_LEGACY_TOKEN_FALLBACK=false
#
# Resend (OTP email). RESEND_API_KEY is read by the server.
# RESEND_FROM_EMAIL=Nassani Admin <onboarding@resend.dev>
#
# PIN for Admin Security page + trusted-device actions when panel auth is on; also bulk offer/manual actions.
# ADMIN_SECURITY_PIN=3030
#
# Optional tuning:
# ADMIN_DEVICE_FP_SALT=
# ADMIN_OTP_HASH_SALT=
# ADMIN_OTP_EXPIRY_MINUTES=5
# ADMIN_OTP_RESEND_PER_HOUR=5
#
# Install analytics reset (danger zone on Analytics page)
# ANALYTICS_RESET_PASSWORD=1975
# ADMIN_ALERT_EMAIL=admin@example.com
# ANALYTICS_RESET_COOLDOWN_MINUTES=60
# ADMIN_OTP_MAX_VERIFY_FAIL=8
# ADMIN_OTP_LOCK_MINUTES=15
# ADMIN_EMERGENCY_SESSION_SECONDS=7200
# DEV ONLY: echo OTP in API response when NODE_ENV !== production
# ADMIN_OTP_DEBUG_RETURN=0
